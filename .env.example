# .env.example — Environment variable reference for Customer Service AI
#
# Copy this file to .env and fill in the values before running the application.
# NEVER commit a .env file containing real secrets to version control.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose up

# ---------------------------------------------------------------------------
# Ollama / LLM settings
# ---------------------------------------------------------------------------

# Base URL for the Ollama API.
# In Docker Compose this should point to the ollama service container.
OLLAMA_BASE_URL=http://localhost:11434

# Name of the LLM model to use.
# Must be pulled with `ollama pull <model>` before starting the app.
# Examples: smollm2:135m  |  llama3.2:3b  |  mistral:7b
LLM_MODEL=smollm2:135m

# Embedding model used by the evaluation script.
EMBEDDING_MODEL=nomic-embed-text

# ---------------------------------------------------------------------------
# Application server settings
# ---------------------------------------------------------------------------

# Host and port for the Uvicorn server.
APP_HOST=0.0.0.0
APP_PORT=8000

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------

# API key for the X-API-Key header.
# Leave empty to disable authentication (development / local mode only).
# In production, generate a strong key: openssl rand -hex 32
API_KEY=

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------

# Maximum number of requests per minute allowed per IP address.
# Also enforced at the nginx layer independently.
RATE_LIMIT_PER_MINUTE=20

# ---------------------------------------------------------------------------
# LLM timeout
# ---------------------------------------------------------------------------

# Seconds to wait for the LLM before returning a 504 Gateway Timeout.
# Increase for larger models (7B+) that take longer to respond.
LLM_TIMEOUT_SECONDS=30

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Python log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------

# Controls log format (JSON in production, colored console in development)
# and other environment-specific behaviors.
# Values: development | production
APP_ENV=development

# ---------------------------------------------------------------------------
# Metrics
# ---------------------------------------------------------------------------

# Set to "true" to expose Prometheus metrics at /metrics.
# Set to "false" to disable the endpoint (e.g. when using a sidecar instead).
METRICS_ENABLED=true

# ---------------------------------------------------------------------------
# Phoenix observability (optional)
# ---------------------------------------------------------------------------

# HTTP endpoint for the Phoenix OTLP trace receiver.
PHOENIX_ENDPOINT=http://localhost:6006

# Set to "true" to enable LangChain tracing via Phoenix / OpenTelemetry.
PHOENIX_ENABLED=true
